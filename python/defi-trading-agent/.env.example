# Axon vault configuration
AXON_VAULT_ADDRESS=0x...your-vault-address...
AXON_CHAIN_ID=84532

# Bot authentication — choose ONE of the two options below:

# Option A: Raw private key (simpler, good for development)
AXON_BOT_PRIVATE_KEY=0x...your-bot-private-key...

# Option B: Encrypted keystore file + passphrase (recommended for production)
# AXON_BOT_KEYSTORE_PATH=./bot-keystore.json
# AXON_BOT_PASSPHRASE=your-strong-passphrase

# Price feed
COINGECKO_API_KEY=  # Optional, free tier works without key
